    // ==================== HELPER FUNCTIONS ====================
    function saveResult(event) {
        event.preventDefault();
        const studentId = parseInt(document.getElementById('resultStudent').value);
        const subject = document.getElementById('resultSubject').value;
        const marks = parseInt(document.getElementById('resultMarks').value);
        let grade = marks >= 80 ? 'A' : marks >= 75 ? 'A-' : marks >= 70 ? 'B+' : marks >= 65 ? 'B' : marks >= 60 ? 'B-' : marks >= 55 ? 'C+' : marks >= 50 ? 'C' : marks >= 45 ? 'C-' : marks >= 40 ? 'D+' : marks >= 35 ? 'D' : marks >= 30 ? 'D-' : 'E';
        schoolData.results.push({ id: schoolData.results.length+1, studentId, subject, marks, grade, term: 1, year: 2024 });
        showToast(`Result saved! Grade: ${grade}`, "success");
        loadModule('enter_results');
    }
    
    function generateReportCard(studentId) {
        const student = schoolData.students.find(s => s.id === studentId);
        const results = schoolData.results.filter(r => r.studentId === studentId);
        const total = results.reduce((s,r)=>s+r.marks,0);
        const average = (total / results.length).toFixed(1);
        let grade = average >= 80 ? 'A' : average >= 70 ? 'B+' : average >= 60 ? 'B' : average >= 50 ? 'C' : 'D';
        
        const element = document.createElement('div');
        element.innerHTML = `
            <div style="padding:30px; font-family:Arial">
                <h1 style="text-align:center">SMART HIGH SCHOOL</h1>
                <p style="text-align:center">P.O. Box 12345, Nairobi | Tel: 0710507524</p>
                <hr>
                <h2>STUDENT REPORT CARD</h2>
                <p><strong>Name:</strong> ${student.name}</p>
                <p><strong>Admission No:</strong> ${student.admissionNo}</p>
                <p><strong>Class:</strong> ${student.class}</p>
                <p><strong>Term:</strong> 1 | <strong>Year:</strong> 2024</p>
                <table border="1" style="width:100%; border-collapse:collapse; margin-top:20px">
                    <tr style="background:#667eea; color:white"><th>Subject</th><th>Marks</th><th>Grade</th><th>Remarks</th></tr>
                    ${results.map(r => `<tr><td>${r.subject}</td><td>${r.marks}</td><td>${r.grade}</td><td>${r.marks>=80?'Excellent':r.marks>=60?'Good':'Improvement Needed'}</td></tr>`).join('')}
                    <tr style="background:#f0f0f0"><td colspan="2"><strong>Average Score</strong></td><td colspan="2"><strong>${average}% - Grade ${grade}</strong></td></tr>
                </table>
                <p style="margin-top:30px"><strong>Class Teacher's Comment:</strong> Good performance, keep it up!</p>
                <p><strong>Principal's Signature:</strong> ____________________</p>
                <p style="text-align:center; margin-top:50px">Generated by Smart High School System</p>
            </div>`;
        html2pdf().from(element).save(`Report_Card_${student.admissionNo}.pdf`);
        showToast("Report card downloaded!", "success");
    }
    
    function downloadFeeStatementPDF(studentId) {
        const student = schoolData.students.find(s => s.id === studentId);
        const totalFee = schoolData.feeStructure.find(f => f.class === student.class)?.amount || 25000;
        const payments = schoolData.payments.filter(p => p.studentId === studentId);
        const paid = payments.reduce((s,p)=>s+p.amount,0);
        const balance = totalFee - paid;
        
        const element = document.createElement('div');
        element.innerHTML = `
            <div style="padding:30px; font-family:Arial">
                <h1 style="text-align:center">SMART HIGH SCHOOL</h1>
                <p style="text-align:center">P.O. Box 12345, Nairobi | Tel: 0710507524</p>
                <hr>
                <h2>FEE STATEMENT</h2>
                <p><strong>Student Name:</strong> ${student.name}</p>
                <p><strong>Admission No:</strong> ${student.admissionNo}</p>
                <p><strong>Class:</strong> ${student.class}</p>
                <table border="1" style="width:100%; border-collapse:collapse; margin-top:20px">
                    <tr style="background:#667eea; color:white"><th>Date</th><th>Receipt No</th><th>Amount Paid (KES)</th><th>Balance (KES)</th></tr>
                    ${payments.map(p => `<tr><td>${p.date}</td><td>${p.receiptNo}</td><td>${p.amount.toLocaleString()}</td><td>${p.balance.toLocaleString()}</td></tr>`).join('')}
                    <tr style="background:#f0f0f0"><td colspan="2"><strong>Total Fees: KES ${totalFee.toLocaleString()}</strong></td><td><strong>Paid: KES ${paid.toLocaleString()}</strong></td><td><strong>Balance: KES ${balance.toLocaleString()}</strong></td></tr>
                </table>
                <p style="margin-top:30px">Please clear your balance before the end of term.</p>
                <p style="text-align:center; margin-top:50px">Generated by Smart High School System</p>
            </div>`;
        html2pdf().from(element).save(`Fee_Statement_${student.admissionNo}.pdf`);
        showToast("Fee statement downloaded!", "success");
    }
    
    function downloadReceiptPDF(paymentId) {
        const payment = schoolData.payments.find(p => p.id === paymentId);
        const student = schoolData.students.find(s => s.id === payment.studentId);
        const element = document.createElement('div');
        element.innerHTML = `
            <div style="padding:30px; font-family:Arial; text-align:center">
                <h1>SMART HIGH SCHOOL</h1>
                <h2>OFFICIAL RECEIPT</h2>
                <p><strong>Receipt No:</strong> ${payment.receiptNo}</p>
                <p><strong>Date:</strong> ${payment.date}</p>
                <hr>
                <p><strong>Received from:</strong> ${student.name}</p>
                <p><strong>Admission No:</strong> ${student.admissionNo}</p>
                <p><strong>Amount:</strong> KES ${payment.amount.toLocaleString()}</p>
                <p><strong>Payment Method:</strong> ${payment.method}</p>
                <p><strong>Balance:</strong> KES ${payment.balance.toLocaleString()}</p>
                <hr>
                <p>Thank you for your payment!</p>
                <p style="margin-top:30px">Authorized Signature: ____________________</p>
            </div>`;
        html2pdf().from(element).save(`Receipt_${payment.receiptNo}.pdf`);
        showToast("Receipt downloaded!", "success");
    }
    
    function generateAdmissionLetter(studentId) {
        const student = schoolData.students.find(s => s.id === studentId);
        const element = document.createElement('div');
        element.innerHTML = `
            <div style="padding:30px; font-family:Arial">
