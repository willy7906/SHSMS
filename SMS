        html2pdf().from(element).save(`ID_Card_${student.admissionNo}.pdf`);
        showToast("ID Card generated!", "success");
    }
    
    function registerForKCSE(studentId) {
        const student = schoolData.students.find(s => s.id === studentId);
        const indexNo = `${new Date().getFullYear()}${student.id.toString().padStart(5,'0')}`;
        schoolData.kcseRegistration.push({ id: schoolData.kcseRegistration.length+1, studentId, indexNo, year: 2024, status: "Registered" });
        showToast(`${student.name} registered for KCSE! Index: ${indexNo}`, "success");
        loadModule('kcse_registration');
    }
    
    function sendBulkSMS(event) {
        event.preventDefault();
        const message = document.getElementById('smsMessage').value;
        schoolData.smsLogs.push({ id: schoolData.smsLogs.length+1, message, date: new Date(), recipients: "All" });
        showToast(`SMS sent to all recipients!`, "success");
        document.getElementById('smsMessage').value = '';
    }
    
    function sendWhatsAppBulk(event) {
        event.preventDefault();
        const message = document.getElementById('waMessage').value;
        schoolData.whatsappLogs = schoolData.whatsappLogs || [];
        schoolData.whatsappLogs.push({ id: (schoolData.whatsappLogs.length||0)+1, message, date: new Date() });
        showToast(`WhatsApp message sent to all parents!`, "success");
        document.getElementById('waMessage').value = '';
    }
    
    function sendBulkEmail(event) {
        event.preventDefault();
        const subject = document.getElementById('emailSubject').value;
        const message = document.getElementById('emailMessage').value;
        schoolData.emailLogs.push({ id: (schoolData.emailLogs?.length||0)+1, subject, message, date: new Date() });
        showToast(`Email sent to all recipients!`, "success");
        event.target.reset();
    }
    
    function simulateMpesaPayment() {
        showToast("M-PESA STK Push sent to customer! Enter PIN to complete.", "success");
        setTimeout(() => {
            showToast("Payment of KES 5,000 received! Receipt sent via SMS.", "success");
        }, 3000);
    }
    
    function processPayroll() {
        showToast("Payroll processed for March 2024! Payslips sent to teachers.", "success");
    }
    
    function markAttendance() {
        const today = new Date().toISOString().split('T')[0];
        showToast(`Attendance marked for today (${today})`, "success");
    }
    
    function showAddAnnouncement() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `<div class="modal-content"><h3>Post Announcement</h3>
            <form onsubmit="addAnnouncement(event)"><div class="form-group"><label>Title</label><input id="annTitle" required></div>
            <div class="form-group"><label>Content</label><textarea id="annContent" rows="4" required></textarea></div>
            <div class="form-group"><label>Target Audience</label><select id="annTarget"><option>All</option><option>Students</option><option>Teachers</option><option>Parents</option></select></div>
            <button type="submit" class="btn btn-primary">Post</button>
            <button type="button" onclick="this.closest('.modal').remove()" class="btn btn-danger">Cancel</button></form></div>`;
        document.body.appendChild(modal);
        modal.style.display = 'flex';
    }
    
    function addAnnouncement(event) {
        event.preventDefault();
        const announcement = {
            id: schoolData.announcements.length + 1,
            title: document.getElementById('annTitle').value,
            content: document.getElementById('annContent').value,
            date: new Date().toISOString().split('T')[0],
            target: document.getElementById('annTarget').value
        };
        schoolData.announcements.push(announcement);
        showToast("Announcement posted!", "success");
        document.querySelector('.modal').remove();
        loadModule('announcements');
    }
    
    function createFinancialChart(collected, expected) {
        const ctx = document.getElementById('financialChart')?.getContext('2d');
        if(ctx) new Chart(ctx, { type: 'bar', data: { labels: ['Collected', 'Expected'], datasets: [{ label: 'Amount (KES)', data: [collected, expected], backgroundColor: ['#28a745', '#667eea'] }] } });
    }
    
