    function showFinancialReports() {
        const totalCollected = schoolData.payments.reduce((s,p)=>s+p.amount,0);
        const totalExpected = schoolData.students.length * 25000;
        const defaulters = schoolData.students.filter(s => {
            const fee = schoolData.feeStructure.find(f => f.class === s.class)?.amount || 25000;
            const paid = schoolData.payments.filter(p => p.studentId === s.id).reduce((sum,p)=>sum+p.amount,0);
            return (fee - paid) > 5000;
        }).length;
        
        const content = `
            <div class="stats-grid">
                <div class="stat-card"><div><h4>Total Collected</h4><div class="stat-value">KES ${totalCollected.toLocaleString()}</div></div></div>
                <div class="stat-card"><div><h4>Expected Revenue</h4><div class="stat-value">KES ${totalExpected.toLocaleString()}</div></div></div>
                <div class="stat-card"><div><h4>Collection Rate</h4><div class="stat-value">${((totalCollected/totalExpected)*100).toFixed(1)}%</div></div></div>
                <div class="stat-card"><div><h4>Defaulters</h4><div class="stat-value">${defaulters}</div></div></div>
            </div>
            <div class="card"><h3>Financial Chart</h3><canvas id="financialChart"></canvas></div>
            <div class="card"><h3>Payment Summary by Class</h3><div class="data-table">${['Form 1','Form 2','Form 3','Form 4'].map(cls => {
                const classStudents = schoolData.students.filter(s => s.class === cls);
                const totalPaid = classStudents.reduce((sum, s) => {
                    return sum + schoolData.payments.filter(p => p.studentId === s.id).reduce((ps,pp)=>ps+pp.amount,0);
                }, 0);
                const expected = classStudents.length * 25000;
                return `<tr><td>${cls}</td><td>${classStudents.length} students</td><td>KES ${totalPaid.toLocaleString()}</td><td>${((totalPaid/expected)*100).toFixed(1)}%</td>`;
            }).join('')}</div></div>
            <button class="btn btn-primary" onclick="downloadFinancialReport()">Download Full Report PDF</button>
            <button class="btn btn-info" onclick="sendWhatsAppReport()">Send Report via WhatsApp</button></div>`;
        document.getElementById('dashboardContent').innerHTML = content;
        setTimeout(() => createFinancialChart(totalCollected, totalExpected), 100);
    }
    
