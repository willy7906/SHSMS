        ],
        
        // Administration
        hostel: [
            { id: 1, studentId: 1, roomNo: "A101", bedNo: "B1", checkIn: "2024-01-10", status: "Occupied" },
            { id: 2, studentId: 2, roomNo: "A102", bedNo: "B2", checkIn: "2024-01-10", status: "Occupied" }
        ],
        discipline: [
            { id: 1, studentId: 1, offense: "Late coming", date: "2024-03-01", action: "Warning", status: "Resolved" }
        ],
        attendance: [
            { id: 1, studentId: 1, date: "2024-03-15", status: "Present", checkIn: "08:00", checkOut: "16:00" },
            { id: 2, studentId: 2, date: "2024-03-15", status: "Absent", reason: "Sick" }
        ],
        leaveRequests: [
            { id: 1, teacherId: 1, startDate: "2024-04-01", endDate: "2024-04-05", reason: "Annual Leave", status: "Pending" }
        ],
        payroll: [
            { id: 1, teacherId: 1, month: "March", year: 2024, basic: 50000, allowance: 10000, deductions: 5000, net: 55000, status: "Paid" }
        ],
        
        // Communication
        announcements: [
            { id: 1, title: "School Opens", content: "School opens on Jan 8th", date: "2024-01-01", target: "All" }
        ],
        smsLogs: [],
        emailLogs: [],
        whatsappLogs: [],
        
        // Documents
        kcseRegistration: [
            { id: 1, studentId: 1, indexNo: "12345678901", year: 2024, status: "Registered" }
        ]
    };
    
    // Credentials
    const credentials = {
        admin: { password: "admin123", name: "System Admin", role: "admin", level: 8 },
        principal: { password: "principal123", name: "Dr. Sarah Johnson", role: "principal", level: 7 },
        dos: { password: "dos123", name: "Mr. Michael Chen", role: "dos", level: 6 },
        accountant: { password: "accountant123", name: "Mrs. Jane Mwangi", role: "accountant", level: 5 },
        teacher: { password: "teacher123", name: "Mr. Peter Omondi", role: "teacher", level: 4, teacherId: 1 },
        student: { password: "student123", name: "John Kamau", role: "student", level: 1, studentId: 1 }
    };
    
    // Navigation Menu
    const navMenu = {
        admin: [
            { category: "Academic", items: ["CBC Assessment", "Exams", "Report Cards", "Timetable", "Subject Allocation", "Class Teacher"] },
            { category: "Finance", items: ["Fee Invoices", "Fee Statements", "Fee Receipts", "M-PESA Integration", "Financial Reports"] },
            { category: "Administration", items: ["Hostel Management", "Discipline Records", "Attendance Reports", "Leave Management", "Staff Payroll"] },
            { category: "Communication", items: ["SMS Notifications", "WhatsApp Notifications", "Email Notifications", "Announcements"] },
            { category: "Documents", items: ["Admission Letters", "Transfer Letters", "Student ID Cards", "KCSE Registration"] }
        ],
        principal: [
            { category: "Academic", items: ["CBC Assessment", "Exams", "Report Cards", "Timetable"] },
            { category: "Finance", items: ["Financial Reports"] },
            { category: "Administration", items: ["Hostel Management", "Discipline Records", "Attendance Reports"] },
            { category: "Communication", items: ["Announcements"] }
        ],
        dos: [
            { category: "Academic", items: ["CBC Assessment", "Exams", "Report Cards", "Timetable", "Subject Allocation", "Class Teacher"] },
            { category: "Administration", items: ["Attendance Reports"] }
        ],
        teacher: [
            { category: "Academic", items: ["CBC Assessment", "Enter Results", "My Timetable"] }
        ],
        accountant: [
            { category: "Finance", items: ["Fee Invoices", "Fee Statements", "Fee Receipts", "M-PESA Integration", "Financial Reports"] }
        ],
        student: [
            { category: "Academic", items: ["My Results", "My Timetable", "Report Card"] },
            { category: "Finance", items: ["Fee Statement", "Payments"] },
            { category: "Communication", items: ["Announcements"] }
        ]
    };
    
    // Role selection
    document.querySelectorAll('.role-card-login').forEach(card => {
        card.addEventListener('click', () => {
            document.querySelectorAll('.role-card-login').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            selectedRole = card.dataset.role;
        });
    });
    
    function togglePassword() {
        const input = document.getElementById('loginPassword');
        const icon = document.querySelector('.toggle-password');
        if (input.type === 'password') { input.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
        else { input.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
    }
    
    function handleLogin() {
        const password = document.getElementById('loginPassword').value;
        if (!selectedRole) { showToast("Select a role", "error"); return; }
        const user = credentials[selectedRole];
        if (user && user.password === password) {
            currentUser = user;
            document.getElementById('loginPage').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            document.getElementById('userNameDisplay').innerHTML = user.name;
            document.getElementById('userRoleDisplay').innerHTML = user.role.toUpperCase();
            showToast(`Welcome ${user.name}!`, "success");
            loadDashboard();
        } else { showToast("Invalid password!", "error"); }
    }
    
    function logout() {
        currentUser = null;
        document.getElementById('loginPage').style.display = 'flex';
        document.getElementById('dashboard').style.display = 'none';
        showToast("Logged out", "info");
    }
    
    function showToast(msg, type) {
        Toastify({ text: msg, duration: 3000, gravity: "top", position: "right",
            backgroundColor: type === 'success' ? "#28a745" : (type === 'error' ? "#dc3545" : "#17a2b8") }).showToast();
    }
    
    function loadDashboard() {
        const nav = document.getElementById('mainNav');
        const menu = navMenu[currentUser.role] || navMenu.student;
        
        nav.innerHTML = menu.map(cat => `
            <div class="nav-category">
                <button class="nav-btn">${cat.category} ▼</button>
                <div class="dropdown-content">
                    ${cat.items.map(item => `<a onclick="loadModule('${item.toLowerCase().replace(/ /g, '_')}')">${item}</a>`).join('')}
                </div>
            </div>
        `).join('');
        
        // Show stats overview
        showStatsOverview();
    }
    
    function showStatsOverview() {
        const content = `
            <div class="stats-grid">
                <div class="stat-card"><div><h4>Total Students</h4><div class="stat-value">${schoolData.students.length}</div></div><i class="fas fa-users" style="font-size:40px; opacity:0.3"></i></div>
                <div class="stat-card"><div><h4>Total Teachers</h4><div class="stat-value">${schoolData.teachers.length}</div></div><i class="fas fa-chalkboard-user" style="font-size:40px; opacity:0.3"></i></div>
                <div class="stat-card"><div><h4>Revenue</h4><div class="stat-value">KES ${schoolData.payments.reduce((s,p)=>s+p.amount,0).toLocaleString()}</div></div><i class="fas fa-money-bill" style="font-size:40px; opacity:0.3"></i></div>
                <div class="stat-card"><div><h4>School Mean</h4><div class="stat-value">${(schoolData.results.reduce((s,r)=>s+r.marks,0)/schoolData.results.length||0).toFixed(1)}%</div></div><i class="fas fa-chart-line" style="font-size:40px; opacity:0.3"></i></div>
            </div>
            <div class="card"><h3>Quick Actions</h3>
                <button class="btn btn-primary" onclick="loadModule('cbc_assessment')">📋 CBC Assessment</button>
                <button class="btn btn-success" onclick="loadModule('fee_invoices')">💰 Fee Invoices</button>
                <button class="btn btn-info" onclick="loadModule('hostel_management')">🏠 Hostel</button>
                <button class="btn btn-warning" onclick="generateReportCard(1)">📄 Report Card</button>
                <button class="btn btn-danger" onclick="sendSMS()">📱 Send SMS</button>
            </div>
            <div class="card"><h3>Recent Announcements</h3>
                ${schoolData.announcements.map(a => `<p><strong>${a.title}</strong> - ${a.content} <small>(${a.date})</small></p>`).join('')}
                <button class="btn btn-primary" onclick="showAddAnnouncement()">+ Add Announcement</button>
            </div>`;
        document.getElementById('dashboardContent').innerHTML = content;
    }
    
    // ==================== ACADEMIC MODULES ====================
    function loadModule(module) {
        if (module === 'cbc_assessment') showCBCAssessment();
        else if (module === 'exams') showExams();
        else if (module === 'report_cards') showReportCards();
        else if (module === 'timetable') showTimetable();
        else if (module === 'subject_allocation') showSubjectAllocation();
        else if (module === 'class_teacher') showClassTeacher();
        else if (module === 'enter_results') showEnterResults();
        else if (module === 'my_results') showMyResults();
        else if (module === 'my_timetable') showMyTimetable();
        else if (module === 'fee_invoices') showFeeInvoices();
        else if (module === 'fee_statements') showFeeStatements();
        else if (module === 'fee_receipts') showFeeReceipts();
        else if (module === 'mpesa_integration') showMpesaIntegration();
        else if (module === 'financial_reports') showFinancialReports();
        else if (module === 'hostel_management') showHostelManagement();
        else if (module === 'discipline_records') showDisciplineRecords();
        else if (module === 'attendance_reports') showAttendanceReports();
        else if (module === 'leave_management') showLeaveManagement();
        else if (module === 'staff_payroll') showStaffPayroll();
        else if (module === 'sms_notifications') showSMSNotifications();
        else if (module === 'whatsapp_notifications') showWhatsAppNotifications();
        else if (module === 'email_notifications') showEmailNotifications();
        else if (module === 'announcements') showAnnouncements();
        else if (module === 'admission_letters') showAdmissionLetters();
        else if (module === 'transfer_letters') showTransferLetters();
        else if (module === 'student_id_cards') showStudentIDCards();
        else if (module === 'kcse_registration') showKCSERegistration();
        else showStatsOverview();
    }
    
    function showCBCAssessment() {
        const content = `
            <div class="card"><h3><i class="fas fa-chart-line"></i> CBC Competency-Based Assessment</h3>
            <div class="data-table"><tr><thead><tr><th>Student</th><th>Subject</th><th>Competency</th><th>Level</th><th>Term</th><th>Action</th></tr></thead>
