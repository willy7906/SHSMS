            { id: 2, class: "Form 4", day: "Monday", period: 2, subject: "English", teacher: "John Mwangi", room: "Class 2" }
        ],
        
        // Finance
        feeStructure: [
            { class: "Form 1", amount: 25000, term: 1, year: 2024 },
            { class: "Form 2", amount: 25000, term: 1, year: 2024 },
            { class: "Form 3", amount: 27000, term: 1, year: 2024 },
            { class: "Form 4", amount: 30000, term: 1, year: 2024 }
        ],
        payments: [
            { id: 1, studentId: 1, amount: 20000, date: "2024-01-15", receiptNo: "RCT001", method: "M-Pesa", transactionId: "MPESA001", balance: 10000 },
            { id: 2, studentId: 2, amount: 30000, date: "2024-01-20", receiptNo: "RCT002", method: "Bank", transactionId: "BANK001", balance: 0 }
        ],
        invoices: [
